# ==========================================
# AgentWill - Configuration
# ==========================================

# Network choice: testnet (Testnet v2)
NETWORK=testnet

# For testing override. If > 0, the principal agent will stop sending heartbeats
# after this many successful transactions, simulating agent failure.
# Set to 0 to run indefinitely.
TESTING_OVERRIDE_STOP_AFTER=3

# The nametag of the principal agent sending the heartbeat
PRINCIPAL_NAMETAG=agentwill_principal

# The nametag of the watcher agent
WATCHER_NAMETAG=agentwill_watcher

# Interval between heartbeats in milliseconds (e.g., 20000 = 20s)
HEARTBEAT_INTERVAL_MS=20000

# Timeout before triggering succession in seconds (e.g., 60 = 60s)
# NOTE: This short value is strictly for demo purposes so reviewers don't have to wait.
# In a real production system, this would be hours or days.
HEARTBEAT_TIMEOUT=60
